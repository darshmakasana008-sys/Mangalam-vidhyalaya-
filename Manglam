<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Manglam Vidhyalaya – The Vision for Future</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=Lato:wght@300;400;700&family=Cinzel:wght@400;700&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --gold: #C9A84C;
      --gold-light: #F0D080;
      --gold-dark: #8B6914;
      --navy: #1A2A4A;
      --navy-light: #243560;
      --sky: #4A90C4;
      --white: #FDFAF3;
      --cream: #F5EDD8;
      --red: #C0392B;
      --orange: #E67E22;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Lato', sans-serif;
      background: var(--white);
      color: var(--navy);
      overflow-x: hidden;
    }

    /* ── NAV ── */
    nav {
      position: fixed; top: 0; width: 100%; z-index: 100;
      background: rgba(26,42,74,0.97);
      backdrop-filter: blur(8px);
      border-bottom: 2px solid var(--gold);
      display: flex; align-items: center; justify-content: space-between;
      padding: 0.6rem 2.5rem;
    }
    .nav-logo {
      display: flex; align-items: center; gap: 0.8rem;
    }
    .nav-logo-circle {
      width: 46px; height: 46px; border-radius: 50%;
      background: var(--gold);
      display: flex; align-items: center; justify-content: center;
      font-family: 'Cinzel', serif;
      font-size: 1.2rem; font-weight: 700;
      color: var(--navy); border: 2px solid var(--gold-light);
      flex-shrink: 0;
    }
    .nav-title {
      font-family: 'Cinzel', serif;
      font-size: 1rem; color: var(--gold-light);
      letter-spacing: 0.06em;
      line-height: 1.2;
    }
    .nav-links {
      display: flex; gap: 2rem; list-style: none;
    }
    .nav-links a {
      color: #CBD5E8; text-decoration: none;
      font-size: 0.82rem; letter-spacing: 0.1em; text-transform: uppercase;
      font-weight: 700; transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--gold-light); }

    /* ── HERO ── */
    .hero {
      min-height: 100vh;
      background: linear-gradient(160deg, var(--navy) 0%, var(--navy-light) 50%, #1a3a5c 100%);
      display: flex; align-items: center; justify-content: center;
      text-align: center;
      position: relative; overflow: hidden;
      padding-top: 72px;
    }
    .hero-bg-rays {
      position: absolute; inset: 0;
      background: radial-gradient(ellipse at 50% 120%, rgba(201,168,76,0.18) 0%, transparent 65%),
                  radial-gradient(ellipse at 80% 10%, rgba(74,144,196,0.1) 0%, transparent 50%);
    }
    .hero-stars {
      position: absolute; inset: 0; overflow: hidden;
    }
    .star {
      position: absolute; width: 2px; height: 2px;
      background: #fff; border-radius: 50%;
      animation: twinkle 3s infinite alternate;
    }
    @keyframes twinkle { from { opacity: 0.2; } to { opacity: 0.9; } }

    .hero-content {
      position: relative; z-index: 2;
      animation: fadeUp 1s ease both;
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(40px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .hero-logo-wrap {
      width: 160px; height: 160px; border-radius: 50%;
      margin: 0 auto 1.5rem;
      border: 4px solid var(--gold);
      box-shadow: 0 0 40px rgba(201,168,76,0.45), 0 0 80px rgba(201,168,76,0.15);
      overflow: hidden;
      background: #fff;
      animation: fadeUp 1s 0.15s ease both;
    }
    .hero-logo-wrap img {
      width: 100%; height: 100%; object-fit: cover;
    }
    .hero-badge {
      display: inline-block;
      border: 1px solid var(--gold);
      color: var(--gold-light);
      font-size: 0.68rem; letter-spacing: 0.2em; text-transform: uppercase;
      padding: 0.25rem 1rem; border-radius: 20px; margin-bottom: 1rem;
      animation: fadeUp 1s 0.25s ease both;
    }
    .hero h1 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2.4rem, 6vw, 4.5rem);
      font-weight: 900; color: #fff;
      line-height: 1.1; margin-bottom: 0.5rem;
      animation: fadeUp 1s 0.3s ease both;
    }
    .hero h1 span { color: var(--gold-light); }
    .hero-sub {
      font-size: 1rem; color: #A0B4CE; margin-bottom: 0.6rem;
      letter-spacing: 0.04em;
      animation: fadeUp 1s 0.4s ease both;
    }
    .hero-motto {
      font-family: 'Playfair Display', serif;
      font-style: italic; color: var(--gold);
      font-size: 1.25rem; margin-bottom: 2.2rem;
      animation: fadeUp 1s 0.5s ease both;
    }
    .hero-btns {
      display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;
      animation: fadeUp 1s 0.6s ease both;
    }
    .btn-primary {
      background: var(--gold);
      color: var(--navy); font-weight: 700;
      padding: 0.8rem 2rem; border-radius: 4px;
      text-decoration: none; font-size: 0.9rem; letter-spacing: 0.06em;
      transition: background 0.2s, transform 0.2s;
      text-transform: uppercase;
    }
    .btn-primary:hover { background: var(--gold-light); transform: translateY(-2px); }
    .btn-outline {
      border: 2px solid var(--gold);
      color: var(--gold-light); font-weight: 700;
      padding: 0.8rem 2rem; border-radius: 4px;
      text-decoration: none; font-size: 0.9rem; letter-spacing: 0.06em;
      transition: background 0.2s, transform 0.2s;
      text-transform: uppercase;
    }
    .btn-outline:hover { background: rgba(201,168,76,0.1); transform: translateY(-2px); }

    .hero-scroll {
      position: absolute; bottom: 2rem; left: 50%; transform: translateX(-50%);
      display: flex; flex-direction: column; align-items: center; gap: 0.3rem;
      color: #6A85A8; font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase;
    }
    .scroll-dot {
      width: 6px; height: 6px; background: var(--gold); border-radius: 50%;
      animation: bounce 1.5s infinite;
    }
    @keyframes bounce { 0%,100%{transform:translateY(0)} 50%{transform:translateY(8px)} }

    /* ── SECTION SHARED ── */
    section { padding: 5rem 1.5rem; }
    .section-label {
      font-size: 0.7rem; letter-spacing: 0.25em; text-transform: uppercase;
      color: var(--gold); font-weight: 700; margin-bottom: 0.5rem;
    }
    .section-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.8rem, 4vw, 2.8rem);
      font-weight: 700; color: var(--navy); margin-bottom: 1rem;
    }
    .section-title span { color: var(--gold-dark); }
    .divider {
      width: 60px; height: 3px;
      background: linear-gradient(90deg, var(--gold), var(--sky));
      margin-bottom: 2rem;
    }
    .container { max-width: 1100px; margin: 0 auto; }

    /* ── ABOUT ── */
    #about { background: var(--cream); }
    .about-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center;
    }
    .about-text p {
      color: #3A4A5C; line-height: 1.85; margin-bottom: 1rem; font-size: 0.97rem;
    }
    .about-logo {
      text-align: center;
    }
    .about-logo-img {
      width: 220px; height: 220px; border-radius: 50%;
      object-fit: cover;
      border: 5px solid var(--gold);
      box-shadow: 0 8px 40px rgba(201,168,76,0.3);
    }
    .values-row {
      display: grid; grid-template-columns: repeat(3,1fr); gap: 1.2rem; margin-top: 2rem;
    }
    .value-card {
      background: var(--navy); color: #fff;
      border-radius: 8px; padding: 1.2rem 1rem; text-align: center;
      border-top: 3px solid var(--gold);
    }
    .value-icon { font-size: 1.8rem; margin-bottom: 0.5rem; }
    .value-card h4 { font-family: 'Playfair Display', serif; font-size: 0.95rem; color: var(--gold-light); margin-bottom: 0.3rem; }
    .value-card p { font-size: 0.78rem; color: #9BADC4; line-height: 1.5; }

    /* ── STATS ── */
    #stats {
      background: var(--navy);
      padding: 3rem 1.5rem;
    }
    .stats-grid {
      display: grid; grid-template-columns: repeat(4,1fr); gap: 1.5rem; text-align: center;
    }
    .stat-item h3 {
      font-family: 'Playfair Display', serif;
      font-size: 2.8rem; font-weight: 900; color: var(--gold);
    }
    .stat-item p { color: #7A98B8; font-size: 0.82rem; letter-spacing: 0.1em; text-transform: uppercase; margin-top: 0.2rem; }

    /* ── PROGRAMS ── */
    #programs { background: var(--white); }
    .programs-grid {
      display: grid; grid-template-columns: repeat(3,1fr); gap: 1.5rem;
    }
    .prog-card {
      border: 1px solid #DDD6C4; border-radius: 10px; overflow: hidden;
      transition: box-shadow 0.3s, transform 0.3s;
    }
    .prog-card:hover { box-shadow: 0 12px 40px rgba(26,42,74,0.14); transform: translateY(-4px); }
    .prog-head {
      background: var(--navy); padding: 1.5rem;
      display: flex; align-items: center; gap: 1rem;
    }
    .prog-icon { font-size: 2rem; }
    .prog-head h3 { font-family: 'Playfair Display', serif; color: var(--gold-light); font-size: 1.1rem; }
    .prog-head p { color: #8AA0B8; font-size: 0.78rem; margin-top: 0.2rem; }
    .prog-body { padding: 1.2rem; }
    .prog-body ul { list-style: none; }
    .prog-body li {
      padding: 0.4rem 0; color: #3A4A5C; font-size: 0.88rem;
      border-bottom: 1px dashed #E5DCC8;
      display: flex; align-items: center; gap: 0.5rem;
    }
    .prog-body li::before { content: "✦"; color: var(--gold); font-size: 0.6rem; }

    /* ── ADMISSIONS ── */
    #admissions { background: var(--cream); }
    .admission-wrap {
      display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: start;
    }
    .admission-info h3 {
      font-family: 'Playfair Display', serif; font-size: 1.4rem;
      color: var(--navy); margin-bottom: 1rem;
    }
    .steps { list-style: none; }
    .steps li {
      display: flex; gap: 1rem; align-items: flex-start;
      padding: 0.8rem 0; border-bottom: 1px solid #DDD6C4;
    }
    .step-num {
      width: 30px; height: 30px; border-radius: 50%;
      background: var(--gold); color: var(--navy);
      display: flex; align-items: center; justify-content: center;
      font-weight: 700; font-size: 0.85rem; flex-shrink: 0;
    }
    .steps li div h4 { font-weight: 700; color: var(--navy); font-size: 0.9rem; margin-bottom: 0.2rem; }
    .steps li div p { color: #6A7A8A; font-size: 0.82rem; }

    /* ── FORM ── */
    .form-card {
      background: var(--navy); border-radius: 12px; padding: 2rem;
      border: 1px solid rgba(201,168,76,0.3);
    }
    .form-card h3 {
      font-family: 'Playfair Display', serif; color: var(--gold-light);
      font-size: 1.3rem; margin-bottom: 1.5rem; text-align: center;
    }
    .form-group { margin-bottom: 1rem; }
    .form-group label { display: block; color: #8AAAC8; font-size: 0.78rem; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 0.4rem; }
    .form-group input,
    .form-group select,
    .form-group textarea {
      width: 100%; padding: 0.7rem 0.9rem;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(201,168,76,0.25);
      border-radius: 6px; color: #fff;
      font-family: 'Lato', sans-serif; font-size: 0.88rem;
      transition: border-color 0.2s;
    }
    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
      outline: none; border-color: var(--gold);
    }
    .form-group select option { background: var(--navy); }
    .form-group textarea { resize: vertical; min-height: 80px; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .submit-btn {
      width: 100%; padding: 0.9rem;
      background: var(--gold); color: var(--navy);
      font-weight: 700; font-size: 0.9rem; letter-spacing: 0.08em;
      text-transform: uppercase; border: none; border-radius: 6px;
      cursor: pointer; transition: background 0.2s, transform 0.2s;
      margin-top: 0.5rem;
    }
    .submit-btn:hover { background: var(--gold-light); transform: translateY(-1px); }
    .success-msg {
      display: none; text-align: center; color: #6DD48A;
      padding: 0.8rem; background: rgba(109,212,138,0.1);
      border-radius: 6px; margin-top: 0.8rem; font-size: 0.88rem;
    }

    /* ── CONTACT ── */
    #contact { background: var(--white); }
    .contact-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: start;
    }
    .contact-item {
      display: flex; gap: 1rem; align-items: flex-start; margin-bottom: 1.5rem;
    }
    .contact-icon {
      width: 44px; height: 44px; background: var(--navy);
      border-radius: 8px; display: flex; align-items: center; justify-content: center;
      font-size: 1.2rem; flex-shrink: 0;
      border: 1px solid var(--gold);
    }
    .contact-item h4 { font-weight: 700; color: var(--navy); margin-bottom: 0.2rem; font-size: 0.9rem; }
    .contact-item p { color: #5A6A7A; font-size: 0.88rem; line-height: 1.6; }

    .contact-form-card {
      background: var(--cream); border-radius: 12px; padding: 2rem;
      border: 1px solid #DDD6C4;
    }
    .contact-form-card h3 {
      font-family: 'Playfair Display', serif;
      color: var(--navy); font-size: 1.3rem; margin-bottom: 1.5rem;
    }
    .contact-form-card .form-group label { color: #5A6A7A; }
    .contact-form-card input,
    .contact-form-card textarea {
      background: #fff; border: 1px solid #CCC4B0; color: var(--navy);
    }
    .contact-form-card input:focus,
    .contact-form-card textarea:focus { border-color: var(--gold); }
    .contact-form-card textarea { min-height: 100px; }

    /* ── FOOTER ── */
    footer {
      background: var(--navy);
      border-top: 2px solid var(--gold);
      padding: 3rem 1.5rem 1.5rem;
      text-align: center;
    }
    .footer-logo { font-family: 'Cinzel', serif; color: var(--gold-light); font-size: 1.4rem; margin-bottom: 0.3rem; }
    .footer-motto { font-family: 'Playfair Display', serif; font-style: italic; color: var(--gold); font-size: 0.9rem; margin-bottom: 1.5rem; }
    .footer-links { display: flex; gap: 2rem; justify-content: center; flex-wrap: wrap; margin-bottom: 1.5rem; }
    .footer-links a { color: #8AAAC8; text-decoration: none; font-size: 0.82rem; transition: color 0.2s; }
    .footer-links a:hover { color: var(--gold-light); }
    .footer-copy { color: #4A6278; font-size: 0.75rem; }

    /* ── RESPONSIVE ── */
    @media (max-width: 800px) {
      .about-grid, .admission-wrap, .contact-grid { grid-template-columns: 1fr; }
      .stats-grid { grid-template-columns: repeat(2,1fr); }
      .programs-grid { grid-template-columns: 1fr; }
      .values-row { grid-template-columns: 1fr 1fr; }
      .nav-links { display: none; }
      .form-row { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="nav-logo">
    <div class="nav-logo-circle">MV</div>
    <div class="nav-title">Manglam Vidhyalaya<br><span style="font-size:0.72rem;color:#6A85A8;font-family:'Lato',sans-serif;letter-spacing:0.04em;">The Vision for Future</span></div>
  </div>
  <ul class="nav-links">
    <li><a href="#about">About</a></li>
    <li><a href="#programs">Programs</a></li>
