<!-- ADMISSIONS -->
<section id="admissions">
  <div class="container">
    <p class="section-label">Admissions</p>
    <h2 class="section-title">Join Our <span>School Family</span></h2>
    <div class="divider"></div>
    <div class="admission-wrap">
      <div class="admission-info">
        <h3>How to Apply</h3>
        <ul class="steps">
          <li>
            <div class="step-num">1</div>
            <div><h4>Enquiry & Registration</h4><p>Fill in the admission form online or visit our school office.</p></div>
          </li>
          <li>
            <div class="step-num">2</div>
            <div><h4>Document Submission</h4><p>Submit birth certificate, transfer certificate, and previous report cards.</p></div>
          </li>
          <li>
            <div class="step-num">3</div>
            <div><h4>Interaction Session</h4><p>A friendly interaction with the child and parents with our principal.</p></div>
          </li>
          <li>
            <div class="step-num">4</div>
            <div><h4>Confirmation & Fees</h4><p>Complete the admission formalities and fee payment to confirm the seat.</p></div>
          </li>
        </ul>
        <div style="margin-top:1.5rem;padding:1rem;background:var(--navy);border-radius:8px;border-left:4px solid var(--gold);">
          <p style="color:#7A9AB8;font-size:0.8rem;">📞 For enquiries call us or visit the school between <strong style="color:var(--gold-light);">9:00 AM – 4:00 PM</strong>, Monday to Saturday.</p>
        </div>
